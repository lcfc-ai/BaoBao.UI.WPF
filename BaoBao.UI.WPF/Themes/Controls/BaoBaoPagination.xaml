<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:BaoBao.UI.WPF.Controls"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/BaoBao.UI.WPF;component/Themes/BaseStyles.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <Style TargetType="{x:Type controls:BaoBaoPagination}">
        <Setter Property="Foreground" Value="{DynamicResource BaoBao_Text_Primary_Brush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:BaoBaoPagination}">
                    <StackPanel Orientation="Horizontal">
                        <!--  Previous  -->
                        <Button
                            x:Name="PART_FirstPageButton"
                            Width="30"
                            Height="30"
                            Margin="2,0"
                            Content="&lt;&lt;"
                            FontSize="16"
                            FontWeight="Bold"
                            Style="{DynamicResource BaoBaoButton}" />
                        <Button
                            x:Name="PART_PreviousPageButton"
                            Width="30"
                            Height="30"
                            Margin="2,0"
                            Content="&lt;"
                            FontSize="16"
                            FontWeight="Bold"
                            Style="{DynamicResource BaoBaoButton}" />

                        <!--  Current Page Info  -->
                        <StackPanel
                            Margin="10,0"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                            <TextBlock
                                VerticalAlignment="Center"
                                Foreground="{TemplateBinding Foreground}"
                                Text="Page" />
                            <TextBox
                                x:Name="PART_PageInput"
                                MinWidth="30"
                                Margin="5,0"
                                HorizontalContentAlignment="Center"
                                Text="{Binding CurrentPage, RelativeSource={RelativeSource TemplatedParent}, Mode=OneWay}" />
                            <TextBlock
                                VerticalAlignment="Center"
                                Foreground="{TemplateBinding Foreground}"
                                Text="/" />
                            <TextBlock
                                Margin="5,0,0,0"
                                VerticalAlignment="Center"
                                Foreground="{TemplateBinding Foreground}"
                                Text="{Binding TotalPages, RelativeSource={RelativeSource TemplatedParent}}" />
                        </StackPanel>

                        <!--  Next  -->
                        <Button
                            x:Name="PART_NextPageButton"
                            Width="30"
                            Height="30"
                            Margin="2,0"
                            Content=">"
                            FontSize="16"
                            FontWeight="Bold"
                            Style="{DynamicResource BaoBaoButton}" />
                        <Button
                            x:Name="PART_LastPageButton"
                            Width="30"
                            Height="30"
                            Margin="2,0"
                            Content=">>"
                            FontSize="16"
                            FontWeight="Bold"
                            Style="{DynamicResource BaoBaoButton}" />

                        <!--  Page Size Changer (Optional)  -->
                        <!--  Simple ComboBox to select 10, 20, 50, 100  -->
                        <ComboBox
                            x:Name="PART_PageSizeComboBox"
                            Width="70"
                            Margin="10,0,0,0"
                            SelectedValue="{Binding PageSize, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                            SelectedValuePath="Content">
                            <ComboBoxItem Content="10" />
                            <ComboBoxItem Content="20" />
                            <ComboBoxItem Content="50" />
                            <ComboBoxItem Content="100" />
                        </ComboBox>
                    </StackPanel>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
