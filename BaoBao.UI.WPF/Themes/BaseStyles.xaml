<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="clr-namespace:BaoBao.UI.WPF.Helpers">

    <!--
        Base Style for all Controls
        Provides consistent Spacing, Typography and Colors
    -->


    <Style x:Key="BaoBaoControlBase" TargetType="Control">
        <Setter Property="Margin" Value="{DynamicResource BaoBao_Margin_Default}" />
        <Setter Property="FontSize" Value="{DynamicResource BaoBao_FontSize_Normal}" />
        <Setter Property="Padding" Value="{DynamicResource BaoBao_Padding_Input}" />
        <Setter Property="Foreground" Value="{DynamicResource BaoBao_Text_Primary_Brush}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
    </Style>

    <Style x:Key="BaoBaoTextBlock" TargetType="TextBlock">
        <Setter Property="Margin" Value="{DynamicResource BaoBao_Margin_Default}" />
        <Setter Property="FontSize" Value="{DynamicResource BaoBao_FontSize_Normal}" />
        <Setter Property="Padding" Value="{DynamicResource BaoBao_Padding_Input}" />
        <Setter Property="Foreground" Value="{DynamicResource BaoBao_Text_Primary_Brush}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
    </Style>

    <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

    <!--
        Base Style for Controls with Borders (Inputs, Buttons etc)
    -->
    <Style
        x:Key="BaoBaoBorderedControlBase"
        BasedOn="{StaticResource BaoBaoControlBase}"
        TargetType="Control">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{DynamicResource BaoBao_Border_Brush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="helpers:ControlAttach.CornerRadius" Value="{DynamicResource BaoBao_CornerRadius_Small}" />
    </Style>

    <!--
        Base Style for Text Inputs (TextBox, PasswordBox, ComboBox)
    -->
    <Style
        x:Key="BaoBaoInputBase"
        BasedOn="{StaticResource BaoBaoBorderedControlBase}"
        TargetType="Control">
        <Setter Property="Background" Value="{DynamicResource BaoBao_Control_Fill_Brush}" />
        <Setter Property="Padding" Value="{DynamicResource BaoBao_Padding_Input}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="helpers:ControlAttach.FocusBorderBrush" Value="{DynamicResource BaoBao_Primary_Brush}" />
    </Style>

</ResourceDictionary>
